-- 3. CONSULTAS CORREGIDAS [cite: 72]
-- ===============================================

-- Consulta 1:
-- Correcion: Se quita AVG(id_cliente). No tiene sentido lógico promediar IDs. [cite: 74, 108]
SELECT nombre, id_cliente
FROM Clientes
WHERE nombre = 'María'; [cite: 76]

-- Consulta 2:
-- Correcion: Se quita UPPER(precio). UPPER() es para texto, 'precio' es DECIMAL. [cite: 78, 109]
SELECT nombre_producto, precio as precio_mayusculas
FROM Productos;

-- Consulta 3:
-- Correcion: Se quita 'nombre_producto' del SELECT.
-- Si usas GROUP BY 'categoria', solo puedes seleccionar 'categoria' y funciones de agregación (como MAX). [cite: 82, 110]
SELECT categoria, MAX(precio) as precio_maximo
FROM Productos
GROUP BY categoria;

-- Consulta 4:
-- Correcion: Esta consulta AHORA FUNCIONA.
-- El error original era que 'fecha_nacimiento' era VARCHAR, pero como la corregimos a DATE, YEAR() es válido. [cite: 84, 100]
SELECT nombre, YEAR(fecha_nacimiento) as año_nacimiento
FROM Clientes;

-- Consulta 5:
SELECT * FROM Pedidos
-- Correcion: Se cambia 'MIL-UNO' (texto) por 1001 (número).
-- 'numero_pedido' es INT, no se puede comparar con texto. [cite: 87, 112]
WHERE numero_pedido = 1001;

-- Consulta 6:
-- Correcion: La unión original (Clientes.id = Productos.id) no tiene sentido lógico. [cite: 91, 111]
-- Se re-escribe la consulta para que tenga sentido:
-- "Mostrar el nombre del cliente y el nombre del producto que compró"
SELECT c.nombre, pr.nombre_producto
FROM Clientes c
JOIN Pedidos p ON c.id_cliente = p.id_cliente
JOIN Detalles_Pedido dp ON p.numero_pedido = dp.numero_pedido
JOIN Productos pr ON dp.id_producto = pr.id_producto;