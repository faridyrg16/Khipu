Create DATABASE TiendaDB;
USE TiendaDB;
CREATE TABLE Clientes (
    id_cliente INT PRIMARY KEY,-- Correcion: Se añade PRIMARY KEY para identificar unívocamente al cliente.
    nombre VARCHAR(50) NOT NULL,
    apellido VARCHAR(50),
    fecha_nacimiento DATE,
    email VARCHAR(100) UNIQUE, -- Correcion: Se cambia CHAR(10) a VARCHAR(15) para dar más flexibilidad (ej. prefijos intl.)
    telefono VARCHAR(15)
);-- Correcion: Las columnas se definen DENTRO de los paréntesis.


/*
-- ERROR ORIGINAL: 'precio' era DECIMAL sin precisión especificada. [cite: 23, 100]
-- ERROR ORIGINAL: Faltaba una PRIMARY KEY. [cite: 98]
*/
CREATE TABLE Productos (
    id_producto INT PRIMARY KEY,-- Correcion: Se añade PRIMARY KEY.
    nombre_producto VARCHAR(100) NOT NULL, 
    precio DECIMAL(10, 2), -- Correcion: Se especifica la precisión para DECIMAL
    categoria VARCHAR(50),
    -- Correcion (Mejora): Se añade un CHECK para asegurar que el stock no sea negativo. [cite: 116]
    stock INT CHECK (stock >= 0)
);


/*
-- ERROR ORIGINAL: Las columnas estaban definidas FUERA de los paréntesis (). [cite: 28, 29]
-- ERROR ORIGINAL: Faltaba la FOREIGN KEY (Clave Foránea) para 'id_cliente'. [cite: 99]
*/
CREATE TABLE Pedidos (
    numero_pedido INT PRIMARY KEY,
    id_cliente INT,
    fecha_pedido DATE,
    total DECIMAL(10, 2),
    estado VARCHAR(20),
    
    -- Correcion: Se añade la FOREIGN KEY para relacionar Pedidos con Clientes. [cite: 99]
    -- Esto asegura que 'id_cliente' DEBE existir en la tabla 'Clientes'.
    FOREIGN KEY (id_cliente) REFERENCES Clientes(id_cliente)
); -- Correcion: Las columnas van DENTRO de los paréntesis.


/*
-- ERROR ORIGINAL: Las columnas estaban definidas FUERA de los paréntesis (). [cite: 40, 41]
-- ERROR ORIGINAL: Faltaba la PRIMARY KEY. [cite: 98]
-- ERROR ORIGINAL: Faltaban las FOREIGN KEYs para 'numero_pedido' y 'id_producto'. [cite: 99]
*/
CREATE TABLE Detalles_Pedido (
    -- Correcion: Se añade PRIMARY KEY.
    id_detalle INT PRIMARY KEY,
    numero_pedido INT,
    id_producto INT,
    cantidad INT,
    precio_unitario DECIMAL(10, 2),
    
    -- Correcion: Se añaden FOREIGN KEYs para la integridad referencial. [cite: 99]
    FOREIGN KEY (numero_pedido) REFERENCES Pedidos(numero_pedido),
    FOREIGN KEY (id_producto) REFERENCES Productos(id_producto)
); -- Correcion: Las columnas van DENTRO de los paréntesis.


